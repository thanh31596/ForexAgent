# Copy to .env and fill values. Never commit .env.

ENV=dev
LOG_LEVEL=INFO

# Market data (optional — yfinance is used if missing)
ALPHA_VANTAGE_API_KEY=

# LLM + embeddings (agent falls back to rule-based signal if missing)
OPENAI_API_KEY=

# News (RAG uses stub headlines if both missing)
MARKETAUX_API_KEY=
FINNHUB_API_KEY=

# Storage
DATABASE_URL=sqlite:///./forexagent.db

# MLflow (file store for local dev)
MLFLOW_TRACKING_URI=file://./mlruns
